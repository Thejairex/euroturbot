# ── API del monitor para páginas de terceros ────────────────────────────────
# Clave de lectura que exigen los endpoints GET a requests cross-origin (terceros).
# Generá una aleatoria y larga, p.ej.: python -c "import secrets;print(secrets.token_urlsafe(32))"
MONITOR_API_KEY=cambia_esto_por_una_key_larga_aleatoria
# Clave opcional para operar el control (start/stop/reset) server-to-server. Vacía = solo same-origin.
MONITOR_ADMIN_KEY=
# Dominios autorizados a consumir la API por CORS, separados por comas.
MONITOR_CORS_ORIGINS=https://cliente-ejemplo.com
