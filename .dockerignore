automatizacion/processed/
automatizacion/outputs/

# Git
.git/
.gitignore

# Archivos del IDE y sistema
.vscode/
.idea/
*.swp
Thumbs.db
.DS_Store

# Docker
Dockerfile
docker-compose.yml
.dockerignore
